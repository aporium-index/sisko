#!/usr/bin/env python3
"""Generate a self-contained HTML dashboard from outpost state files.

Reads all symlinks in outposts/*.md, extracts YAML frontmatter,
and renders a sortable, color-coded HTML table.

Usage:
  ./generate-dashboard          # writes dashboard.html
  ./generate-dashboard --md     # writes dashboard.md (human-readable)
"""

import os
import sys
import re
from datetime import date, datetime

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
SISKO_ROOT = os.path.dirname(SCRIPT_DIR)
OUTPOSTS_DIR = os.path.join(SISKO_ROOT, "outposts")

STATE_ORDER = {
    "operational": 0, "transiting": 1, "commissioning": 2,
    "dormant": 3, "decommissioned": 4, "destroyed": 5
}
PRIORITY_ORDER = {"P1": 0, "P2": 1, "P3": 2, "P4": 3}
TIER_ORDER = {"tier-0": 0, "tier-1": 1, "tier-2": 2, "tier-3": 3}
CONDITION_COLORS = {
    "condition-green": "#22c55e",
    "yellow-alert": "#eab308",
    "red-alert": "#ef4444",
    "adrift": "#6b7280",
}


def parse_frontmatter(path):
    """Extract YAML frontmatter from a markdown file. Returns dict."""
    try:
        with open(path) as f:
            content = f.read()
    except (OSError, FileNotFoundError):
        return {}

    fm_match = re.match(r'^---\s*\n(.*?)\n---', content, re.DOTALL)
    if not fm_match:
        return {}

    data = {}
    for line in fm_match.group(1).split('\n'):
        line = line.strip()
        if ':' not in line or line.startswith('#'):
            continue
        key, _, val = line.partition(':')
        key = key.strip()
        val = val.strip().strip('"').strip("'")
        if isinstance(val, str):
            if val.startswith('[') and val.endswith(']'):
                val = [v.strip().strip('"').strip("'") for v in val[1:-1].split(',') if v.strip()]
            elif val.lower() == 'true':
                val = True
            elif val.lower() == 'false':
                val = False
            elif val.lower() == 'null':
                val = None
        data[key] = val
    return data


def first_body_line(path):
    """Get first non-empty line after frontmatter (the 'focus' line)."""
    try:
        with open(path) as f:
            content = f.read()
    except (OSError, FileNotFoundError):
        return "—"

    parts = re.split(r'^---\s*$', content, maxsplit=2, flags=re.MULTILINE)
    if len(parts) < 3:
        return "—"

    body = parts[2].strip()
    for line in body.split('\n'):
        stripped = line.strip()
        if stripped and not stripped.startswith('#'):
            return stripped[:120]
    return "—"


def days_ago(date_str):
    """Calculate days since given date string."""
    try:
        d = datetime.strptime(date_str, "%Y-%m-%d").date()
        return (date.today() - d).days
    except (ValueError, TypeError):
        return None


def resolve_symlink(path):
    """Resolve a symlink to its absolute real path."""
    return os.path.realpath(path)


def load_outposts():
    """Load all outpost state files via symlinks."""
    outposts = []
    if not os.path.isdir(OUTPOSTS_DIR):
        return outposts

    for fname in sorted(os.listdir(OUTPOSTS_DIR)):
        if not fname.endswith('.md'):
            continue
        path = os.path.join(OUTPOSTS_DIR, fname)
        real_path = resolve_symlink(path)
        slug = fname.replace('-state.md', '')
        data = parse_frontmatter(path)
        data['_slug'] = slug
        data['_real_path'] = real_path
        data['_focus'] = first_body_line(path)
        data['_stale_days'] = days_ago(data.get('last_active'))
        outposts.append(data)

    def sort_key(o):
        return (
            TIER_ORDER.get(o.get('criticality', 'tier-3'), 99),
            PRIORITY_ORDER.get(o.get('priority', 'P4'), 99),
            STATE_ORDER.get(o.get('state', 'dormant'), 99),
            o.get('name', o.get('_slug', '')),
        )

    outposts.sort(key=sort_key)
    return outposts


def compliance_summary(outposts):
    """Compute compliance stats."""
    total = len(outposts)
    agents_count = sum(1 for o in outposts if o.get('has_agents_md'))
    gitignore_count = sum(1 for o in outposts if o.get('has_gitignore'))
    green = sum(1 for o in outposts if o.get('condition') == 'condition-green')
    yellow = sum(1 for o in outposts if o.get('condition') == 'yellow-alert')
    red = sum(1 for o in outposts if o.get('condition') == 'red-alert')
    adrift = sum(1 for o in outposts if o.get('condition') == 'adrift')
    operational = sum(1 for o in outposts if o.get('state') == 'operational')
    dormant = sum(1 for o in outposts if o.get('state') == 'dormant')
    return {
        'total': total, 'agents': agents_count, 'gitignore': gitignore_count,
        'compliance_score': agents_count + gitignore_count,
        'max_compliance': total * 2,
        'green': green, 'yellow': yellow, 'red': red, 'adrift': adrift,
        'operational': operational, 'dormant': dormant,
    }


def state_badge(state):
    badges = {
        'operational': '<span class="badge badge-blue">operational</span>',
        'dormant': '<span class="badge badge-gray">dormant</span>',
        'commissioning': '<span class="badge badge-purple">commissioning</span>',
        'transiting': '<span class="badge badge-yellow">transiting</span>',
        'decommissioned': '<span class="badge badge-gray">decommissioned</span>',
        'destroyed': '<span class="badge badge-red">destroyed</span>',
    }
    return badges.get(state, f'<span class="badge">{state}</span>')


def condition_badge(condition):
    colors = {
        'condition-green': 'green', 'yellow-alert': 'yellow',
        'red-alert': 'red', 'adrift': 'gray',
    }
    c = colors.get(condition, 'gray')
    return f'<span class="dot dot-{c}"></span> {condition}' if condition else '—'


def stale_indicator(stale_days, threshold):
    if stale_days is None:
        return ''
    if stale_days > threshold:
        return ' <span class="stale" title="Stale: {} days">&#9888;</span>'.format(stale_days)
    return ''


def generate_html(outposts):
    stats = compliance_summary(outposts)
    today = date.today().isoformat()

    rows = []
    for o in outposts:
        slug = o.get('_slug', '')
        name = o.get('name', slug)
        state = o.get('state', 'unknown')
        condition = o.get('condition', '')
        priority = o.get('priority', '—')
        tier = o.get('criticality', '—')
        last_active = o.get('last_active', '—')
        focus = o.get('_focus', '—')
        threshold = int(o.get('stale_threshold_days', 14))
        stale = stale_indicator(o.get('_stale_days'), threshold)
        real_path = o.get('_real_path', '')
        file_url = f'file://{real_path}' if real_path else f'outposts/{slug}-state.md'

        condition_html = condition_badge(condition) if state == 'operational' else '—'

        rows.append(f'''        <tr>
          <td><a href="{file_url}">{name}</a></td>
          <td>{state_badge(state)}</td>
          <td>{condition_html}</td>
          <td>{priority}</td>
          <td>{tier}</td>
          <td>{last_active}{stale}</td>
          <td class="focus">{focus}</td>
        </tr>''')

    active_rows = []
    for o in outposts:
        stale_days = o.get('_stale_days')
        if stale_days is not None and stale_days <= 7:
            active_rows.append(
                f'        <li><strong>{o.get("name", o.get("_slug"))}</strong> — {o.get("last_active")}</li>'
            )

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>sisko dashboard</title>
<style>
  body {{ font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 1100px; margin: 0 auto; padding: 24px; background: #0d1117; color: #c9d1d9; }}
  h1 {{ font-size: 20px; margin-bottom: 4px; }}
  .subtitle {{ color: #8b949e; font-size: 13px; margin-bottom: 24px; }}
  table {{ width: 100%; border-collapse: collapse; font-size: 14px; }}
  th {{ text-align: left; padding: 8px 12px; border-bottom: 1px solid #21262d; color: #8b949e; font-weight: 500; font-size: 12px; text-transform: uppercase; }}
  td {{ padding: 10px 12px; border-bottom: 1px solid #21262d; }}
  tr:hover {{ background: #161b22; }}
  a {{ color: #58a6ff; text-decoration: none; }}
  a:hover {{ text-decoration: underline; }}
  .focus {{ color: #8b949e; font-size: 13px; max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }}
  .badge {{ display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 500; }}
  .badge-blue {{ background: #1f6feb33; color: #58a6ff; }}
  .badge-green {{ background: #23863633; color: #3fb950; }}
  .badge-yellow {{ background: #9e6a0333; color: #d2991d; }}
  .badge-red {{ background: #da363333; color: #f85149; }}
  .badge-gray {{ background: #30363d; color: #8b949e; }}
  .badge-purple {{ background: #a371f733; color: #a371f7; }}
  .dot {{ display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 4px; }}
  .dot-green {{ background: #3fb950; }}
  .dot-yellow {{ background: #d2991d; }}
  .dot-red {{ background: #f85149; }}
  .dot-gray {{ background: #6b7280; }}
  .stale {{ color: #d2991d; cursor: help; }}
  .stats {{ display: flex; gap: 24px; margin: 24px 0; flex-wrap: wrap; }}
  .stat {{ background: #161b22; border: 1px solid #21262d; border-radius: 6px; padding: 12px 16px; min-width: 100px; }}
  .stat-label {{ font-size: 11px; color: #8b949e; text-transform: uppercase; }}
  .stat-value {{ font-size: 24px; font-weight: 600; margin-top: 4px; }}
  .section-title {{ font-size: 16px; margin: 28px 0 12px; color: #f0f6fc; }}
  .blocker {{ color: #f85149; }}
  .recent {{ margin: 0; padding: 0; list-style: none; }}
  .recent li {{ padding: 4px 0; font-size: 14px; }}
  .footer {{ margin-top: 32px; padding-top: 16px; border-top: 1px solid #21262d; color: #484f58; font-size: 12px; }}
</style>
</head>
<body>
<h1>sisko dashboard</h1>
<p class="subtitle">Derived from outpost state files. Generated {today}.</p>

<div class="stats">
  <div class="stat"><div class="stat-label">Outposts</div><div class="stat-value">{stats['total']}</div></div>
  <div class="stat"><div class="stat-label">Operational</div><div class="stat-value" style="color:#3fb950">{stats['operational']}</div></div>
  <div class="stat"><div class="stat-label">Dormant</div><div class="stat-value" style="color:#8b949e">{stats['dormant']}</div></div>
  <div class="stat"><div class="stat-label">Compliance</div><div class="stat-value">{stats['compliance_score']}/{stats['max_compliance']}</div></div>
  <div class="stat"><div class="stat-label">Green</div><div class="stat-value" style="color:#3fb950">{stats['green']}</div></div>
  <div class="stat"><div class="stat-label">Alerts</div><div class="stat-value" style="color:#d2991d">{stats['yellow']}</div></div>
</div>

<div class="section-title">All Outposts</div>
<table>
<thead>
  <tr><th>Outpost</th><th>State</th><th>Condition</th><th>Priority</th><th>Tier</th><th>Active</th><th>Focus</th></tr>
</thead>
<tbody>
{chr(10).join(rows)}
</tbody>
</table>

<div class="section-title">Recently Active</div>
<ul class="recent">
{chr(10).join(active_rows) if active_rows else '        <li>No recent activity.</li>'}
</ul>

<p class="footer">sisko control plane &middot; <code>bin/generate-dashboard</code> &middot; zero dependencies</p>
</body>
</html>"""


def main():
    outposts = load_outposts()
    if not outposts:
        print("No outpost state files found.", file=sys.stderr)
        sys.exit(1)

    output = os.path.join(SISKO_ROOT, "dashboard.html")
    with open(output, 'w') as f:
        f.write(generate_html(outposts))
    print(f"dashboard.html written ({len(outposts)} outposts)")

    # Also update dashboard.md references if needed
    print("Done.")


if __name__ == '__main__':
    main()
